# Sanity CMS — copia este archivo como .env.local y rellena los valores
NEXT_PUBLIC_SANITY_PROJECT_ID=xxxxxxxxxx
NEXT_PUBLIC_SANITY_DATASET=production

# Web3Forms — access key del formulario de contacto (panel de Web3Forms)
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Google Apps Script — URL del deployment "Web App" que escribe en el Sheet de leads
GOOGLE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/xxxxxxxx/exec

# Dashboard AEO oculto (/aeo?auth=...) — server-only, genera el tuyo con `openssl rand -hex 24`
AEO_DASHBOARD_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
